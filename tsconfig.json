{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "allowJs": true,
    "declaration": true,
    "declarationMap": true,
    "skipLibCheck": true
  },
  "include": ["src", "src/*.d.ts", "types/encryptjs.d.ts"],
  "exclude": ["src/**/__tests__", "node_modules"],
  "typeRoots": ["./types", "./node_modules/@types"]
}
