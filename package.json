{
  "name": "@programminggiantpanda/sunsynk-optimizer",
  "version": "0.1.0",
  "description": "Home Assistant add-on that optimises Sunsynk battery charging using Octopus Agile prices and Solcast solar forecasts. Fetches live battery state from HA, calculates cheapest grid import slots before peak, sets the Sunsynk min charge threshold, and publishes results back to HA sensors.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepare": "npm run build",
    "example": "tsc -p tsconfig.json && node dist/example.js",
    "start": "node -r dotenv/config dist/optimizer/index.js",
    "dev": "ts-node -r dotenv/config src/optimizer/index.ts",
    "test": "vitest run"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "sunsync",
    "sunsynk",
    "api",
    "mincharge",
    "charging"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "base64-string": "^1.1.3",
    "dotenv": "^16.6.1",
    "encryptjs": "^2.0.0",
    "jsencrypt": "^3.5.4"
  },
  "devDependencies": {
    "@types/node": "^20.4.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.6.0",
    "vitest": "^4.0.18"
  }
}
